# ──────────────────────────────────────────────────────────────────────────────
# AIQUIRE WEBSITE — ENVIRONMENT VARIABLES EXAMPLE
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in the values.
# IMPORTANT: Never commit .env.local to source control.

# ─── SITE CONFIGURATION ───────────────────────────────────────────────────────
# The public URL of your website (used for SEO, OG images and sitemap)
NEXT_PUBLIC_SITE_URL=https://aiquire.ai

# ─── EXTERNAL SERVICES ────────────────────────────────────────────────────────
# URL for booking discovery calls via Calendly (Used in Contact page)
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/aiquire/discovery-call

# ─── DATABASE CONFIGURATION (SUPABASE) ─────────────────────────────────────────
# Your Supabase project URL (Found in Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase Anon Key (Safe for client-side usage)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# SupABASE Service Role Key (SECRET: Only for server-side, bypasses RLS)
# DO NOT EXPOSE THIS IN THE BROWSER (no NEXT_PUBLIC_ prefix)
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection string (for migrations or ORMs like Prism/Drizzle)
DATABASE_URL=

# ─── CONTACT FORM & EMAILS (FUTURE USE) ───────────────────────────────────────
# API Key for sending emails (e.g. Resend.com)
# RESEND_API_KEY=re_123456789

# Endpoint for form submissions (internal or external)
# CONTACT_FORM_ENDPOINT=/api/contact

# ─── ANALYTICS & MONITORING (FUTURE USE) ──────────────────────────────────────
# Google Analytics Measurement ID (starts with G-)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Microsoft Clarity or other heatmap analytics
# NEXT_PUBLIC_CLARITY_ID=XXXXXXXXXX

# Vercel Environment (automatically set on Vercel)
# NEXT_PUBLIC_VERCEL_ENV=production
